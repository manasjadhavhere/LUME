# Production environment variables for Lume

# App configuration
VITE_APP_TITLE=Lume - Beauty Booking
VITE_APP_DESCRIPTION=Premium mobile platform for booking professional makeup artists

# API configuration (for future backend integration)
# VITE_API_BASE_URL=https://api.lumeapp.com

# Feature flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_PWA=true

# Performance settings
VITE_LAZY_LOADING=true

# Base URL for deployment (can be overridden by build environment)
VITE_BASE_URL=/